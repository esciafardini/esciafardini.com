# VHS Tape: FZF File Finder
# Run: vhs tapes/fzf-files.tape

Output gifs/fzf-files.gif

Set Shell "zsh"
Set FontSize 14
Set Width 1200
Set Height 600
Set Theme "Kanagawa Dragon"

Type "nvim"
Enter
Sleep 1s

# Open fzf file finder with <Space>ff
Type " ff"
Sleep 1s

# Type a search query
Type "options"
Sleep 1s

# Select and open
Enter
Sleep 1s

# Show the file opened
Sleep 2s
